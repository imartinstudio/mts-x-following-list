{
  "name": "mts-x-following-list",
  "version": "0.2.3",
  "private": true,
  "type": "module",
  "description": "Standalone Chrome MV3 extension to filter, select, and bulk-unfollow on X following lists. 独立项目：X 关注列表筛选与批量取关。",
  "scripts": {
    "build": "node ./build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:smoke": "vitest run tests/smoke.test.ts && node ./scripts/dist-smoke.mjs",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.304",
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
