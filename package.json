{
  "name": "mts-x-following-list",
  "version": "0.2.3",
  "private": true,
  "type": "module",
  "description": "Standalone Chrome MV3 extension to filter, select, and bulk-unfollow on X following lists. 独立项目：X 关注列表筛选与批量取关。",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imartinstudio/mts-x-following-list.git"
  },
  "homepage": "https://github.com/imartinstudio/mts-x-following-list#readme",
  "bugs": {
    "url": "https://github.com/imartinstudio/mts-x-following-list/issues"
  },
  "scripts": {
    "build": "node ./build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:smoke": "vitest run tests/smoke.test.ts && node ./scripts/dist-smoke.mjs",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
